@model JobNeedsWebApp.Models.JobViewModel

@{
    ViewData["Title"] = "Details";
}
<div class="card border-primary mb-3">
    <div class="card-header bg-primary text-white fw-bold">
        Job Position Details
    </div>
    <hr />
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.JobTitle)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.JobTitle)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.JobDescription)
            </dt>
            <dd class="col-sm-10">
                @Html.Raw(Model.JobDescription)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Location)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Location)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.JobType)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.JobType)
            </dd>
            <dt class="col-sm-2">
                Experience
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.MinExperience) - @Html.DisplayFor(model => model.MaxExperience)
            </dd>
            <dt class="col-sm-2">
                Salary
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.MinSalary) -  @Html.DisplayFor(model => model.MaxSalary)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Currency)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Currency)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Skills)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Skills)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PostedDate)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PostedDate)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ExpiryDate)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ExpiryDate)
            </dd>
            @*   <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd> *@
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.IsActive)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.IsActive)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Url)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Url)
            </dd>
            <dt class="col-sm-2">
                CompanyName
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.CompanyName) - @Html.DisplayFor(model => model.CompanyLogo)
            </dd>
        </dl>
    </div>
</div>
<div>
    @if (CurrentUser != null)
    {
        <a asp-controller="Jobs" asp-area="Jobseeker" asp-action="Apply" asp-route-id="@Model.JobId" class="btn btn-primary">
            Apply
        </a>    
    }
    else
    {
        <a asp-controller="Account" asp-action="Login"
           asp-route-returnUrl="@Url.Action("Apply", "Jobs", new { id = Model.JobId })"
           class="btn btn-warning">
            Login to Apply
        </a>
    } |
    <a asp-action="Index" class="btn btn-primary">Back to List</a>
</div>
