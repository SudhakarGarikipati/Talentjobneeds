@model IEnumerable<JobNeedsWebApp.Models.JobViewModel>

@{
    ViewData["Title"] = "SearchResults";
}

<table class="table table-striped table-hover table-bordered border-primary">
    <thead class="table-primary">
        <tr>
            <th hidden="hidden">
                @Html.DisplayNameFor(model => model.JobId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.JobTitle)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Location)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.JobType)
            </th>
            <th>
                Experience @* @Html.DisplayNameFor(model => model.MaxExperience) *@
            </th>
            <th>
                Salary
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Skills)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PostedDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Url)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CompanyName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CompanyLogo)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody class="table-info">
        @foreach (var item in Model)
        {
            <tr>
                <td hidden="hidden">
                    @Html.DisplayFor(modelItem => item.JobId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.JobTitle)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Location)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.JobType)
                </td>
                <td>
                    @item.MinExperience  -  @item.MaxExperience (Yrs)
                </td>
                <td>
                    @item.MaxSalary (@item.Currency))
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Skills)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.PostedDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Url)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CompanyName)
                </td>
                <td>
                    <img src="@item.CompanyLogo" />
                </td>
                <td>
                    @Html.ActionLink("Details", "Details", new { id = item.JobId }) |
                    @if (CurrentUser != null)
                    {
                        <a asp-controller="Jobs" asp-area="Jobseeker" asp-action="Apply" asp-route-id="@item.JobId" class="btn btn-primary">
                            Apply
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>



